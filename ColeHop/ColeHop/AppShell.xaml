<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ColeHop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ColeHop"
    Title="ColeHop">

    <ShellContent
        Title="Inicio"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Profesores"
        ContentTemplate="{DataTemplate views:DashboardTeacherPage}"
        Route="DashboardTeacher" />

    <ShellContent
        Title="Tutores"
        ContentTemplate="{DataTemplate views:DashboardTutorPage}"
        Route="DashboardTutor" />

</Shell>
