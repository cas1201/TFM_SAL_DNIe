<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ColeHop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ColeHop.View"
    Title="ColeHop">

    <!-- LOGIN -->
    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- DASHBOARD TUTOR -->
    <ShellContent
        Route="dashboard/tutor"
        ContentTemplate="{DataTemplate views:DashboardTutorPage}" />

    <!-- DASHBOARD TEACHER -->
    <ShellContent
        Route="dashboard/teacher"
        ContentTemplate="{DataTemplate views:DashboardTeacherPage}" />

</Shell>