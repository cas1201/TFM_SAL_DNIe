<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ColeHop"
             xmlns:converters="clr-namespace:ColeHop.Converters"
             x:Class="ColeHop.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:PickupStatusColorConverter x:Key="PickupStatusColorConverter" />
            <converters:PickupStatusTextConverter x:Key="PickupStatusTextConverter" />
            <converters:CollectionContainsConverter x:Key="CollectionContainsConverter" />
            <converters:EqualityConverter x:Key="EqualityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
