<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.Views.AuthorizedPersonDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings">

    <ScrollView>
        <VerticalStackLayout Style="{StaticResource PageContainer}">

            <Border
                Stroke="{DynamicResource Gray300}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                Padding="20"
                Margin="0,0,0,16">

                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="{x:Static res:AppResources.PersonalInfo}"
                        Style="{StaticResource SubSectionTitle}" />

                    <Label
                        Style="{StaticResource FormLabel}"
                        Text="{x:Static res:AppResources.Name}" />

                    <Entry
                        Style="{StaticResource FormEntry}"
                        Text="{Binding Name}"
                        Placeholder="{x:Static res:AppResources.Name}" />

                    <Label
                        Style="{StaticResource FormLabel}"
                        Text="{x:Static res:AppResources.LastName}" />

                    <Entry
                        Style="{StaticResource FormEntry}"
                        Text="{Binding LastName}"
                        Placeholder="{x:Static res:AppResources.LastName}" />

                    <Label
                        Style="{StaticResource FormLabel}"
                        Text="{x:Static res:AppResources.DNI}" />

                    <Entry
                        Style="{StaticResource FormEntry}"
                        Text="{Binding Dni}"
                        Placeholder="12345678A"
                        Keyboard="Text" />

                    <Label
                        Style="{StaticResource FormLabel}"
                        Text="{x:Static res:AppResources.Relationship}" />

                    <Entry
                        Style="{StaticResource FormEntry}"
                        Text="{Binding Relationship}"
                        Placeholder="Ej: Abuelo/a, Tío/a" />
                </VerticalStackLayout>
            </Border>

            <Button
                Style="{StaticResource PrimaryButton}"
                Text="{x:Static res:AppResources.SaveChanges}"
                Command="{Binding SaveChangesCommand}"
                Margin="0,0,0,8" />

            <Button
                Style="{StaticResource DangerButton}"
                Text="{x:Static res:AppResources.Delete}"
                Command="{Binding DeleteCommand}" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{DynamicResource Primary}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
