<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.Views.DashboardTutorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:utils="clr-namespace:ColeHop.Helpers"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings">

    <Grid>
        <!-- Logo pegado arriba -->
        <Image Source="logo.png" HeightRequest="80" Aspect="AspectFit" HorizontalOptions="Center"
               VerticalOptions="Start" Margin="0,24,0,0" />

        <ScrollView>
            <Grid Padding="24" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16"
                  VerticalOptions="Center">

                <!-- Card: Hijos -->
                <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{StaticResource Primary}"
                        Shadow="{StaticResource CardShadow}" Padding="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToChildrenCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label FontFamily="MaterialSymbolsRounded" Text="{x:Static utils:MaterialIcon.Child}"
                               FontSize="44" HorizontalOptions="Center" TextColor="White" />
                        <Label Text="{x:Static res:AppResources.MyChildren}"
                               FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card: Personas autorizadas -->
                <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{StaticResource Tertiary}"
                        Shadow="{StaticResource CardShadow}" Padding="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAuthorizedPersonsCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label FontFamily="MaterialSymbolsRounded" Text="{x:Static utils:MaterialIcon.Group}"
                               FontSize="44" HorizontalOptions="Center" TextColor="White" />
                        <Label Text="{x:Static res:AppResources.AuthorizedPersonsMenu}"
                               FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card: Calendario (colspan 2) -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{StaticResource Success}"
                        Shadow="{StaticResource CardShadow}" Padding="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAuthorizationCalendarCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label FontFamily="MaterialSymbolsRounded" Text="{x:Static utils:MaterialIcon.CalendarMonth}"
                               FontSize="44" HorizontalOptions="Center" TextColor="White" />
                        <Label Text="{x:Static res:AppResources.AuthorizationCalendar}"
                               FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="White" />
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>

        <!-- FAB Ajustes -->
        <Button
            Style="{StaticResource FabButton}"
            HorizontalOptions="End"
            VerticalOptions="End"
            Command="{Binding GoToSettingsCommand}">
            <Button.ImageSource>
                <FontImageSource
                    FontFamily="MaterialSymbolsRounded"
                    Glyph="{x:Static utils:MaterialIcon.Settings}"
                    Size="28"
                    Color="White" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>