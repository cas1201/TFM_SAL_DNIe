<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.Views.DashboardTeacherPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:utils="clr-namespace:ColeHop.Helpers"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings">

    <Grid>
        <!-- Logo pegado arriba -->
        <Image Source="logo.png" HeightRequest="80" Aspect="AspectFit" HorizontalOptions="Center"
               VerticalOptions="Start" Margin="0,24,0,0" />

        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

                <!-- Card: Lista de recogidas del día -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{StaticResource Primary}"
                        Shadow="{StaticResource CardShadow}" Padding="0" HeightRequest="140">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDailyPickupListCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label FontFamily="MaterialSymbolsRounded" Text="{x:Static utils:MaterialIcon.ListAlt}"
                               FontSize="48" HorizontalOptions="Center" TextColor="White" />
                        <Label Text="{x:Static res:AppResources.DailyPickupList}"
                               FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card: Altas pendientes -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{StaticResource Tertiary}"
                        Shadow="{StaticResource CardShadow}" Padding="0" HeightRequest="140">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToPendingApprovalsCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label FontFamily="MaterialSymbolsRounded" Text="{x:Static utils:MaterialIcon.HowToReg}"
                               FontSize="48" HorizontalOptions="Center" TextColor="White" />
                        <Label Text="{x:Static res:AppResources.PendingApprovals}"
                               FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="White" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- FAB Ajustes - esquina inferior derecha -->
        <ImageButton
            Command="{Binding GoToSettingsCommand}"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            BackgroundColor="{DynamicResource Primary}"
            Padding="12"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,20,20"
            Shadow="{StaticResource CardShadow}">
            <ImageButton.Source>
                <FontImageSource
                    FontFamily="MaterialSymbolsRounded"
                    Glyph="{x:Static utils:MaterialIcon.Settings}"
                    Size="24"
                    Color="White" />
            </ImageButton.Source>
        </ImageButton>
    </Grid>
</ContentPage>