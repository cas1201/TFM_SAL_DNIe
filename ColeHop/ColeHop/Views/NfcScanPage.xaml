<ContentPage
    x:Class="ColeHop.Views.NfcScanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings"
    xmlns:helpers="clr-namespace:ColeHop.Helpers">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24" VerticalOptions="Center">

            <Label
                Text="{Binding PickupTitle}"
                FontSize="20"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center" />

            <VerticalStackLayout
                Spacing="8"
                IsVisible="{Binding ShowCanInput}">

                <Label
                    Text="{x:Static res:AppResources.EnterCanPrompt}"
                    FontSize="14"
                    HorizontalTextAlignment="Center" />

                <Entry
                    x:Name="CanEntry"
                    Text="{Binding Can}"
                    Placeholder="000000"
                    Keyboard="Numeric"
                    MaxLength="6"
                    HorizontalTextAlignment="Center"
                    FontSize="24"
                    WidthRequest="200"
                    HorizontalOptions="Center" />

                <Button
                    Text="{x:Static res:AppResources.StartScan}"
                    Clicked="OnStartScanClicked"
                    BackgroundColor="{DynamicResource Primary}"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0,16,0,0" />
            </VerticalStackLayout>

            <Border
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceDimLight}, Dark={StaticResource SurfaceDimDark}}"
                Padding="32"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding IsScanning}">

                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                    <!-- Icono NFC (esperando) -->
                    <Label
                        Text="{x:Static helpers:MaterialIcon.Contactless}"
                        FontFamily="MaterialSymbolsRounded"
                        FontSize="80"
                        TextColor="{DynamicResource Primary}"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding DniDetected, Converter={StaticResource InvertedBoolConverter}}" />

                    <!-- Icono éxito (detectado) -->
                    <Label
                        Text="{x:Static helpers:MaterialIcon.CheckCircle}"
                        FontFamily="MaterialSymbolsRounded"
                        FontSize="80"
                        TextColor="{DynamicResource Success}"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding DniDetected}" />

                    <!-- Instrucciones de posicionamiento (antes de detectar) -->
                    <Label
                        Text="{x:Static res:AppResources.NfcPositionInstructions}"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        TextColor="{DynamicResource Gray400}"
                        IsVisible="{Binding DniDetected, Converter={StaticResource InvertedBoolConverter}}" />

                    <!-- Mensaje de mantener (después de detectar) -->
                    <Label
                        Text="{x:Static res:AppResources.NfcKeepDniOnReader}"
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{DynamicResource Success}"
                        IsVisible="{Binding DniDetected}" />

                    <ActivityIndicator
                        IsRunning="{Binding IsScanning}"
                        Color="{DynamicResource Primary}"
                        WidthRequest="48"
                        HeightRequest="48" />

                    <Label
                        Text="{x:Static res:AppResources.BringDnieClose}"
                        FontSize="16"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding DniDetected, Converter={StaticResource InvertedBoolConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Label
                Text="{Binding ScanStatus}"
                FontSize="16"
                HorizontalTextAlignment="Center"
                TextColor="{DynamicResource Gray400}"
                Margin="0,8,0,0" />

            <Button
                Text="{x:Static res:AppResources.Cancel}"
                Command="{Binding CancelScanCommand}"
                IsVisible="{Binding IsScanning}"
                BackgroundColor="Transparent"
                TextColor="{DynamicResource Primary}"
                BorderWidth="1"
                BorderColor="{DynamicResource Primary}"
                CornerRadius="12"
                HeightRequest="50"
                Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>