<ContentPage
    x:Class="ColeHop.View.AuthorizationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Crear autorización"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                Margin="0,10,0,30" />

            <Label
                Text="Fecha"
                FontAttributes="Bold"
                FontSize="16" />

            <DatePicker
                Date="{Binding SelectedDate}"
                MinimumDate="{Binding MinimumDate}"
                Format="dd/MM/yyyy" />

            <Label
                Text="Niños autorizados"
                FontAttributes="Bold"
                FontSize="16"
                Margin="0,10,0,0" />

            <CollectionView
                ItemsSource="{Binding Children}"
                SelectionMode="Multiple"
                SelectedItems="{Binding SelectedChildren}"
                HeightRequest="150">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="12"
                            Margin="0,4"
                            Stroke="LightGray"
                            StrokeShape="RoundRectangle 8">

                            <Label Text="{Binding Name}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label
                Text="Persona autorizada"
                FontAttributes="Bold"
                FontSize="16"
                Margin="0,10,0,0" />

            <Picker
                ItemsSource="{Binding AuthorizedPeople}"
                ItemDisplayBinding="{Binding FullName}"
                SelectedItem="{Binding SelectedAuthorizedPerson}" />

            <Button
                Text="Crear autorización"
                Command="{Binding CreateAuthorizationCommand}"
                BackgroundColor="{DynamicResource Primary}"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="50"
                Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>