<ContentPage
    x:Class="ColeHop.View.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:utils="clr-namespace:ColeHop.Utils"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="20"
            VerticalOptions="Center">

            <Label
                Text="{x:Static res:AppResources.AppName}"
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TextColor="{DynamicResource Primary}"
                Margin="0,20" />

            <Border Style="{StaticResource FormCard}">
                <VerticalStackLayout Style="{StaticResource FormContainer}">
                    <Entry
                        Style="{StaticResource FormEntry}"
                        Placeholder="{x:Static res:AppResources.UsernameOrEmail}"
                        Text="{Binding Username}" />

                    <Entry
                        Style="{StaticResource FormEntry}"
                        Placeholder="{x:Static res:AppResources.Password}"
                        IsPassword="True"
                        Text="{Binding Password}" />
                </VerticalStackLayout>
            </Border>

            <Button
                Style="{StaticResource PrimaryButton}"
                Text="{x:Static res:AppResources.LoginAsTeacher}"
                Command="{Binding GoToTeacherCommand}">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="MaterialSymbolsRounded"
                        Glyph="{x:Static utils:MaterialIcon.Login}"
                        Size="22"
                        Color="White" />
                </Button.ImageSource>
            </Button>

            <Button
                Style="{StaticResource OutlineMenuButton}"
                Text="{x:Static res:AppResources.LoginAsTutor}"
                Command="{Binding GoToTutorCommand}">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="MaterialSymbolsRounded"
                        Glyph="{x:Static utils:MaterialIcon.Login}"
                        Size="22"
                        Color="{DynamicResource Primary}" />
                </Button.ImageSource>
            </Button>

            <Label
                Text="{x:Static res:AppResources.CreateNewAccount}"
                TextColor="{DynamicResource Gray500}"
                FontSize="13"
                TextDecorations="Underline"
                HorizontalOptions="Center"
                Margin="0,10,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToSignupCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <ActivityIndicator
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>