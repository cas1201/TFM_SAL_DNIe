<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.View.PendingApprovalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:ColeHop.ViewModel"
    xmlns:model="clr-namespace:ColeHop.Model.Domain"
    xmlns:utils="clr-namespace:ColeHop.Utils"
    xmlns:res="clr-namespace:ColeHop.Resources.Strings"
    x:DataType="viewmodel:PendingApprovalsViewModel">

    <RefreshView
        IsRefreshing="{Binding IsRefreshing}"
        Command="{Binding RefreshCommand}">

        <Grid>
            <CollectionView ItemsSource="{Binding PendingChildren}" Margin="16">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="0,40">
                        <Label
                            Style="{StaticResource EmptyStateTitle}"
                            Text="{x:Static res:AppResources.NoPendingApprovals}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Child">
                        <Border
                            Style="{StaticResource Card}"
                            Margin="0,6">
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Text="{Binding FullName}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Text="{Binding Grade}"
                                    FontSize="13"
                                    TextColor="{DynamicResource Gray600}" />

                                <ImageButton
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    BackgroundColor="{DynamicResource Success}"
                                    Padding="8"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:PendingApprovalsViewModel}}, Path=ApproveCommand}"
                                    CommandParameter="{Binding .}">
                                    <ImageButton.Source>
                                        <FontImageSource
                                            FontFamily="MaterialSymbolsRounded"
                                            Glyph="{x:Static utils:MaterialIcon.Check}"
                                            Size="20"
                                            Color="White" />
                                    </ImageButton.Source>
                                </ImageButton>

                                <ImageButton
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="2"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    BackgroundColor="{DynamicResource Danger}"
                                    Padding="8"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:PendingApprovalsViewModel}}, Path=RejectCommand}"
                                    CommandParameter="{Binding .}">
                                    <ImageButton.Source>
                                        <FontImageSource
                                            FontFamily="MaterialSymbolsRounded"
                                            Glyph="{x:Static utils:MaterialIcon.Close}"
                                            Size="20"
                                            Color="White" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                </CollectionView>

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center" />
        </Grid>
    </RefreshView>
</ContentPage>
