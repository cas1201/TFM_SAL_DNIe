<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.View.DashboardTutorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Panel Tutor">

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label
            Text="Panel del Tutor"
            FontSize="26"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <Button
            Text="Mis hijos"
            Command="{Binding GoToChildrenCommand}" />

        <Button
            Text="Personas autorizadas"
            Command="{Binding GoToAuthorizedPersonsCommand}" />

        <Button
            Text="Calendario de autorizaciones"
            Command="{Binding GoToAuthorizationCalendarCommand}" />

        <Button
            Text="Escanear NFC"
            Command="{Binding GoToNfcScanCommand}" />

    </VerticalStackLayout>
</ContentPage>