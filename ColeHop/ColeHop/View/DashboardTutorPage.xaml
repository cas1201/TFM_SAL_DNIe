<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ColeHop.View.DashboardTutorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Panel del Tutor"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                Margin="0,20,0,40" />

            <Button
                Text="Mis hijos"
                Command="{Binding GoToChildrenCommand}"
                BackgroundColor="White"
                TextColor="{DynamicResource Primary}"
                BorderColor="{DynamicResource Primary}"
                BorderWidth="2"
                CornerRadius="12"
                HeightRequest="60"
                FontSize="16"
                FontAttributes="Bold" />

            <Button
                Text="Personas autorizadas"
                Command="{Binding GoToAuthorizedPersonsCommand}"
                BackgroundColor="White"
                TextColor="{DynamicResource Primary}"
                BorderColor="{DynamicResource Primary}"
                BorderWidth="2"
                CornerRadius="12"
                HeightRequest="60"
                FontSize="16"
                FontAttributes="Bold" />

            <Button
                Text="Calendario de autorizaciones"
                Command="{Binding GoToAuthorizationCalendarCommand}"
                BackgroundColor="White"
                TextColor="{DynamicResource Primary}"
                BorderColor="{DynamicResource Primary}"
                BorderWidth="2"
                CornerRadius="12"
                HeightRequest="60"
                FontSize="16"
                FontAttributes="Bold" />

            <BoxView
                HeightRequest="1"
                Color="LightGray"
                Margin="0,20" />

            <Button
                Text="Cerrar sesión"
                Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent"
                TextColor="Gray"
                BorderWidth="1"
                BorderColor="Gray"
                CornerRadius="12"
                HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>