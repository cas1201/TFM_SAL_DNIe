<ContentPage
    x:Class="ColeHop.View.AuthorizationCalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Calendario de Autorizaciones">

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label
            Text="Autorizaciones por día"
            FontAttributes="Bold"
            FontSize="20"
            HorizontalOptions="Center" />

        <toolkit:CalendarView
            SelectedDate="{Binding SelectedDate}"
            Margin="0,10" />

        <Label
            Text="{Binding SelectedDate, StringFormat='Autorizaciones para {0:dd/MM/yyyy}'}"
            FontSize="16"
            FontAttributes="Bold" />

        <CollectionView
            ItemsSource="{Binding AuthorizationsForSelectedDay}"
            SelectionMode="None"
            Margin="0,5">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Stroke="LightGray"
                        StrokeThickness="1"
                        Padding="12"
                        Margin="6"
                        StrokeShape="RoundRectangle 8">

                        <VerticalStackLayout>
                            <Label Text="{Binding ChildName}" FontAttributes="Bold" />
                            <Label Text="{Binding AuthorizedPerson}" />
                            <Label
                                Text="{Binding TimeRange}"
                                TextColor="Gray"
                                FontSize="12" />
                        </VerticalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
</ContentPage>