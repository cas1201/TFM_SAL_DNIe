<ContentPage
    x:Class="ColeHop.View.DailyPickupListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Recogidas del día">

    <CollectionView
        ItemsSource="{Binding PickupList}"
        SelectionMode="None"
        Margin="10">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border
                    Stroke="LightGray"
                    StrokeThickness="1"
                    Padding="12"
                    Margin="6"
                    StrokeShape="RoundRectangle 8">

                    <VerticalStackLayout>
                        <Label Text="{Binding ChildName}" FontAttributes="Bold" />
                        <Label Text="{Binding AuthorizedPerson}" />
                        <Label
                            Text="{Binding PickupTime}"
                            TextColor="Gray"
                            FontSize="12" />
                    </VerticalStackLayout>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>