<ContentPage
    x:Class="ColeHop.View.NfcScanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Escaneo NFC">

    <VerticalStackLayout Padding="24" Spacing="20" HorizontalOptions="Center">

        <Label
            Text="Acerque el DNI electrónico al lector"
            FontSize="18"
            HorizontalOptions="Center" />

        <Image
            Source="dotnet_bot.png"
            WidthRequest="150" />

        <ActivityIndicator
            IsRunning="{Binding IsScanning}"
            IsVisible="{Binding IsScanning}" />

        <Label
            Text="{Binding ScanStatus}"
            HorizontalOptions="Center"
            TextColor="Gray" />

    </VerticalStackLayout>
</ContentPage>