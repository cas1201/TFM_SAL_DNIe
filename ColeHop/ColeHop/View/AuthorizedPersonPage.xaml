<ContentPage
    x:Class="ColeHop.View.AuthorizedPersonPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Personas Autorizadas">

    <CollectionView
        ItemsSource="{Binding AuthorizedPersons}"
        SelectionMode="None"
        Margin="10">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border
                    Stroke="DarkGray"
                    StrokeThickness="1"
                    Padding="10"
                    Margin="5"
                    StrokeShape="RoundRectangle 8">

                    <VerticalStackLayout>
                        <Label Text="{Binding FullName}" FontSize="18" />
                        <Label Text="{Binding Relationship}" FontSize="14" TextColor="Gray" />
                    </VerticalStackLayout>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>