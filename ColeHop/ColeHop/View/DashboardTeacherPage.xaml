<ContentPage
    x:Class="ColeHop.View.DashboardTeacherPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Panel Profesor">

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label
            Text="Panel del Profesor"
            FontSize="26"
            FontAttributes="Bold" />

        <Button
            Text="Lista de recogidas del día"
            Command="{Binding GoToDailyPickupListCommand}" />

        <Button
            Text="Escanear NFC"
            Command="{Binding GoToNfcScanCommand}" />

    </VerticalStackLayout>
</ContentPage>