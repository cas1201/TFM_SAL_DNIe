<ContentPage
    x:Class="ColeHop.View.DashboardTeacherPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Panel Profesor">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Panel del Profesor"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                Margin="0,20,0,40" />

            <Border
                StrokeThickness="0"
                BackgroundColor="{DynamicResource Primary}"
                Padding="20"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Gestión de recogidas"
                        FontSize="18"
                        TextColor="White"
                        FontAttributes="Bold" />
                    <Label
                        Text="Gestione las recogidas diarias de los alumnos"
                        FontSize="14"
                        TextColor="White"
                        Opacity="0.9" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Lista de recogidas del día"
                Command="{Binding GoToDailyPickupListCommand}"
                BackgroundColor="White"
                TextColor="{DynamicResource Primary}"
                BorderColor="{DynamicResource Primary}"
                BorderWidth="2"
                CornerRadius="12"
                HeightRequest="60"
                FontSize="16"
                FontAttributes="Bold" />

            <Button
                Text="Escanear DNI"
                Command="{Binding GoToNfcScanCommand}"
                BackgroundColor="White"
                TextColor="{DynamicResource Primary}"
                BorderColor="{DynamicResource Primary}"
                BorderWidth="2"
                CornerRadius="12"
                HeightRequest="60"
                FontSize="16"
                FontAttributes="Bold" />

            <BoxView
                HeightRequest="1"
                Color="LightGray"
                Margin="0,20" />

            <Button
                Text="Cerrar sesión"
                Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent"
                TextColor="Gray"
                BorderWidth="1"
                BorderColor="Gray"
                CornerRadius="12"
                HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>