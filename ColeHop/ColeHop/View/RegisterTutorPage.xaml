<ContentPage
    x:Class="ColeHop.View.RegisterTutorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Registro Tutor">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Entry Placeholder="Nombre" Text="{Binding FirstName}" />
            <Entry Placeholder="Apellidos" Text="{Binding LastName}" />
            <Entry Placeholder="Email" Text="{Binding Email}" />
            <Entry Placeholder="Contraseña" IsPassword="True" Text="{Binding Password}" />

            <Button
                Text="Registrar"
                Command="{Binding RegisterCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>