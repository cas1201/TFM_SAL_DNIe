<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#4361EE</Color>
    <Color x:Key="PrimaryDark">#7B93F5</Color>
    <Color x:Key="PrimaryDarkText">#1A1A2E</Color>
    <Color x:Key="Secondary">#E0E7FF</Color>
    <Color x:Key="SecondaryDarkText">#6C83E8</Color>
    <Color x:Key="Tertiary">#F72585</Color>
    <Color x:Key="Accent">#FFBE0B</Color>
    <Color x:Key="Success">#06D6A0</Color>
    <Color x:Key="Danger">#EF476F</Color>
    <Color x:Key="Surface">#F8F9FE</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray700">#333333</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Semantic colors (AppThemeBinding in consuming styles/views) -->
    <Color x:Key="CardBackgroundLight">White</Color>
    <Color x:Key="CardBackgroundDark">#2A2A2A</Color>
    <Color x:Key="FormCardBackgroundLight">#F5F5F5</Color>
    <Color x:Key="FormCardBackgroundDark">#2A2A2A</Color>
    <Color x:Key="SurfaceDimLight">#F0F0F0</Color>
    <Color x:Key="SurfaceDimDark">#333333</Color>
    <Color x:Key="RejectionBannerLight">#FFF0F0</Color>
    <Color x:Key="RejectionBannerDark">#3D1F1F</Color>
    <Color x:Key="SuccessBannerLight">#f0f9f4</Color>
    <Color x:Key="SuccessBannerDark">#1A2E1F</Color>
    <Color x:Key="SummaryBannerLight">#F0F0FF</Color>
    <Color x:Key="SummaryBannerDark">#1F1F3D</Color>
    <Color x:Key="SuccessGreen">#28a745</Color>
    <Color x:Key="SuccessGreenDark">#4CAF72</Color>
    <Color x:Key="TextSecondaryLight">#555</Color>
    <Color x:Key="TextSecondaryDark">#AAAAAA</Color>

    <!-- Popup icon background colors -->
    <Color x:Key="DangerBgLight">#FFEBEE</Color>
    <Color x:Key="DangerBgDark">#3D1F1F</Color>
    <Color x:Key="SuccessBgLight">#E8F5E9</Color>
    <Color x:Key="SuccessBgDark">#1A2E1F</Color>
    <Color x:Key="WarningBgLight">#FFF8E1</Color>
    <Color x:Key="WarningBgDark">#3D3A1F</Color>
    <Color x:Key="InfoBgLight">#E0E7FF</Color>
    <Color x:Key="InfoBgDark">#1F1F3D</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>